{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 3000 --ip 0.0.0.0",
    "deploy": "wrangler deploy --minify src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply my-d1-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply my-d1-db --remote"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "drizzle-orm": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "drizzle-kit": "latest",
    "wrangler": "^4.0.0"
  }
}
