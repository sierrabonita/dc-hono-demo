{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 3001 --ip 0.0.0.0",
    "deploy": "wrangler deploy --minify src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply my-d1-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply my-d1-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "latest",
    "hono": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260525.1",
    "drizzle-kit": "latest",
    "wrangler": "^4.0.0"
  }
}
