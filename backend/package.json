{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 3001 --ip 0.0.0.0",
    "deploy": "wrangler deploy --minify src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply my-d1-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply my-d1-db --remote",
    "db:seed": "npx tsx src/db/seeds/index.ts"
  },
  "dependencies": {
    "@dc-hono-demo/shared": "*",
    "@hono/graphql-server": "^0.7.0",
    "drizzle-orm": "latest",
    "graphql": "^16.14.1",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260525.1",
    "@types/node": "^25.9.2",
    "drizzle-kit": "latest",
    "wrangler": "^4.0.0"
  },
  "volta": {
    "node": "26.3.0",
    "yarn": "4.16.0"
  }
}
